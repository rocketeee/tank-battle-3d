; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via text for version control.

[application]

config/name="萌坦大战 Roguelike"
config/description="Q版3D坦克大战 Roguelike - 三大战场 / 技能Build / 横屏手游"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
SettingsManager="*res://scripts/autoload/settings_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4

[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

3d_physics/layer_1="environment"
3d_physics/layer_2="player"
3d_physics/layer_3="enemy"
3d_physics/layer_4="bullet_player"
3d_physics/layer_5="bullet_enemy"
3d_physics/layer_6="pickup"

[rendering]

renderer/rendering_method="forward_plus"
textures/vram_compression/import_etc2_astc=true
anti_aliasing/quality/msaa_3d=2
environment/defaults/default_clear_color=Color(0.2, 0.2, 0.25, 1)
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
