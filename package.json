{
  "name": "tank-battle-3d",
  "version": "1.0.0",
  "description": "Q版 3D 坦克大战 — mobile chibi tank battle game (Three.js + Capacitor)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
